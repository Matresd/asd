local RedBarrierNoClip = {
    Name = "RedBarrierNoClip",
    Enabled = false,
    touched = {}
}

function RedBarrierNoClip.IsRedBarrierPart(part)
    if not part or not part:IsA("BasePart") then return false end
    local name = part.Name:lower()
    local fullName = part:GetFullName():lower()
    local isBarrier = name:find("barrier") or fullName:find("barrier")
    local isRedName = name:find("red") or fullName:find("red")
    local c = part.Color
    local isRedColor = c.R > 0.45 and c.R > c.G * 1.2 and c.R > c.B * 1.2
    return isBarrier and (isRedName or isRedColor)
end

function RedBarrierNoClip.ApplyToBarrierPart(part)
    if not RedBarrierNoClip.IsRedBarrierPart(part) then return end
    if RedBarrierNoClip.touched[part] then return end
    RedBarrierNoClip.touched[part] = {
        CanCollide = part.CanCollide,
        CanQuery = part.CanQuery
    }
    part.CanCollide = false
    part.CanQuery = false
end

function RedBarrierNoClip.RestoreAll()
    for part, original in pairs(RedBarrierNoClip.touched) do
        if part and part.Parent and original then
            part.CanCollide = original.CanCollide
            part.CanQuery = original.CanQuery
        end
    end
    RedBarrierNoClip.touched = {}
end

function RedBarrierNoClip.OnEnable()
    for _, desc in ipairs(Workspace:GetDescendants()) do
        if desc:IsA("BasePart") then
            RedBarrierNoClip.ApplyToBarrierPart(desc)
        end
    end

    local addedConn = Workspace.DescendantAdded:Connect(function(desc)
        if not ModuleManager.IsEnabled("RedBarrierNoClip") then return end
        if desc:IsA("BasePart") then
            RedBarrierNoClip.ApplyToBarrierPart(desc)
        end
    end)
    ModuleManager.AddConnection("RedBarrierNoClip", addedConn)

    local keepConn = RunService.Heartbeat:Connect(function()
        if not ModuleManager.IsEnabled("RedBarrierNoClip") then return end
        for part, _ in pairs(RedBarrierNoClip.touched) do
            if part and part.Parent then
                part.CanCollide = false
                part.CanQuery = false
            end
        end
    end)
    ModuleManager.AddConnection("RedBarrierNoClip", keepConn)
end

function RedBarrierNoClip.OnDisable()
    RedBarrierNoClip.RestoreAll()
end

