    for _, data in pairs(ESPPlayers.byUserId) do
        if data.bb and data.bb.Parent then data.bb:Destroy() end
        if data.hl and data.hl.Parent then data.hl:Destroy() end
    end
    ESPPlayers.byUserId = {}
end

