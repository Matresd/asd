-- Get character components safely
local function getHumanoid()
    local char = player.Character
    if char then
        return char:FindFirstChild("Humanoid")
    end
    return nil
end

local function disconnectStatHumanoidConns()
    for _, conn in ipairs(statHumanoidConns) do
        if conn and conn.Disconnect then
            conn:Disconnect()
        end
    end
    statHumanoidConns = {}
end

local function applyDesiredStats(hum)
    if not hum then return end
    if desiredWalkSpeed ~= nil then
        hum.WalkSpeed = desiredWalkSpeed
    end
    if desiredJumpPower ~= nil then
        hum.JumpPower = desiredJumpPower
    end
end

local function bindHumanoidStatGuards(hum)
    if not hum then return end
    disconnectStatHumanoidConns()

    applyDesiredStats(hum)

    local wsConn = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if desiredWalkSpeed ~= nil and math.abs(hum.WalkSpeed - desiredWalkSpeed) > 0.01 then
            hum.WalkSpeed = desiredWalkSpeed
        end
    end)
    table.insert(statHumanoidConns, wsConn)

    local jpConn = hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if desiredJumpPower ~= nil and math.abs(hum.JumpPower - desiredJumpPower) > 0.01 then
            hum.JumpPower = desiredJumpPower
        end
    end)
    table.insert(statHumanoidConns, jpConn)
end

local function ensureStatLoop()
    if statApplyConn and statApplySteppedConn then return end
    statApplyConn = statApplyConn or RunService.Heartbeat:Connect(function()
        local hum = getHumanoid()
        if not hum then return end
        applyDesiredStats(hum)
    end)
    -- Extra enforcement because some games constantly override humanoid stats.
    statApplySteppedConn = statApplySteppedConn or RunService.Stepped:Connect(function()
        local hum = getHumanoid()
        if not hum then return end
        applyDesiredStats(hum)
    end)
end

