function ESPPlayers.OnEnable()
    ESPPlayers.byUserId = {}

    local function ensureForPlayer(plr)
        if plr == player then return end
        if not plr.Character then return end
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local uid = plr.UserId
        if ESPPlayers.byUserId[uid] then return end

        local hl = Instance.new("Highlight")
        hl.Name = "YBA_ESP_PlayerHL"
        hl.Parent = plr.Character
        hl.FillTransparency = 1
        hl.OutlineTransparency = 0
        hl.OutlineColor = Color3.new(0, 1, 0)

        local bb = createNameBillboard(hrp, plr.Name, Color3.new(0, 1, 0))
        ESPPlayers.byUserId[uid] = {hl = hl, bb = bb}
    end

    local function rescan()
        for _, plr in Players:GetPlayers() do
            ensureForPlayer(plr)
        end
    end

    rescan()

    local playerAddedConn = Players.PlayerAdded:Connect(function(plr)
        local c = plr.CharacterAdded:Connect(function()
            task.wait(0.5)
            ensureForPlayer(plr)
        end)
        ModuleManager.AddConnection("ESPPlayers", c)
        task.defer(function()
            task.wait(0.5)
            ensureForPlayer(plr)
        end)
    end)
    ModuleManager.AddConnection("ESPPlayers", playerAddedConn)

    for _, plr in Players:GetPlayers() do
        if plr ~= player then
            local c = plr.CharacterAdded:Connect(function()
                task.wait(0.5)
                ensureForPlayer(plr)
            end)
            ModuleManager.AddConnection("ESPPlayers", c)
        end
    end

    local acc = 0
    local rescanConn = RunService.Heartbeat:Connect(function(dt)
        if not ModuleManager.IsEnabled("ESPPlayers") then return end
        acc += dt
        if acc >= 0.6 then
            acc = 0
            rescan()
        end
    end)
    ModuleManager.AddConnection("ESPPlayers", rescanConn)
end

