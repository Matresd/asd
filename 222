    end

    local function hasPickupIndicator(inst)
        if inst:FindFirstChildWhichIsA("TouchTransmitter", true) then return true end
        if inst:FindFirstChildWhichIsA("ProximityPrompt", true) then return true end
        if inst:FindFirstChildWhichIsA("ClickDetector", true) then return true end
        return false
    end

    local function classifyItem(inst)
        local name = inst.Name:lower()
        if name:find("rokakaka") or name:find("fruit") then return true, "Rokakaka" end
        if name:find("requiem") then return true, "Requiem Arrow" end
        if name:find("arrow") then return true, "Stand Arrow" end
        if name:find("corpse") or name:find("saint") then return true, "Corpse Part" end
        if name:find("cash") or name:find("coin") or name:find("money") then return true, "Money" end
        return false, nil
    end

    local function classifyFromPrompt(prompt)
        local obj = ""
        local act = ""
        pcall(function()
            obj = tostring(prompt.ObjectText or "")
            act = tostring(prompt.ActionText or "")
        end)
        local combined = (obj .. " " .. act):lower()
        if combined:find("rokakaka") or combined:find("fruit") then return true, "Rokakaka" end
        if combined:find("requiem") then return true, "Requiem Arrow" end
        if combined:find("arrow") then return true, "Stand Arrow" end
        if combined:find("corpse") or combined:find("saint") then return true, "Corpse Part" end
        if combined:find("cash") or combined:find("coin") or combined:find("money") then return true, "Money" end
        if combined:find("pick up") and obj ~= "" then
            return true, obj
        end
        return false, nil
    end

    local function ensureForItem(inst, displayName)
        if ESPItems.byInstance[inst] then return end
        if findHumanoidModelAncestor(inst) then return end
        if not hasPickupIndicator(inst) then return end

        local part = getItemPart(inst)
        if not part then return end

        local bb = createNameBillboard(part, displayName, Color3.new(1, 1, 0))
        ESPItems.byInstance[inst] = {bb = bb}
    end

    local function getPromptRoot(prompt)
        if not prompt or not prompt.Parent then return nil, nil end
        local attach = prompt.Parent
        if attach:IsA("Attachment") and attach.Parent then
            attach = attach.Parent
        end
        local part = attach
        if part and not part:IsA("BasePart") and part:IsA("Model") then
            part = part:FindFirstChildWhichIsA("BasePart", true)
        end
        if not part or not part:IsA("BasePart") then return nil, nil end

        local root = part
        if part.Parent and part.Parent:IsA("Model") then
            root = part.Parent
        end
        return root, part
    end

    local function ensureForPrompt(prompt)
        if not prompt:IsA("ProximityPrompt") then return end
        local ok, display = classifyFromPrompt(prompt)
        if not ok then return end

        local root, part = getPromptRoot(prompt)
        if not root or not part then return end
        if ESPItems.byInstance[root] then return end
        if findHumanoidModelAncestor(root) then return end

        local bb = createNameBillboard(part, display, Color3.new(1, 1, 0))
        ESPItems.byInstance[root] = {bb = bb}
    end

    local function rescan()
        for _, desc in Workspace:GetDescendants() do
            if desc:IsA("ProximityPrompt") then
                ensureForPrompt(desc)
            end
        end

        for _, desc in Workspace:GetDescendants() do
            local ok, display = classifyItem(desc)
            if ok then
                ensureForItem(desc, display)
            end
        end
    end

    rescan()

    local itemAdded = Workspace.DescendantAdded:Connect(function(desc)
        if not ModuleManager.IsEnabled("ESPItems") then return end
        task.wait(0.2)
        if desc:IsA("ProximityPrompt") then
            ensureForPrompt(desc)
            return
        end
        local ok, display = classifyItem(desc)
        if ok then ensureForItem(desc, display) end
    end)
    ModuleManager.AddConnection("ESPItems", itemAdded)

    local acc = 0
    local rescanConn = RunService.Heartbeat:Connect(function(dt)
        if not ModuleManager.IsEnabled("ESPItems") then return end
        acc += dt
        if acc >= 0.6 then
            acc = 0
            rescan()
        end
    end)
    ModuleManager.AddConnection("ESPItems", rescanConn)
end

function ESPItems.OnDisable()
    for _, data in pairs(ESPItems.byInstance) do
        if data.bb and data.bb.Parent then data.bb:Destroy() end
    end
    ESPItems.byInstance = {}
end

-- ESP NPC - 3D box (Highlight) + name
local ESPNPC = {
    Name = "ESPNPC",
    Enabled = false,
    byInstance = {}
}

function ESPNPC.OnEnable()
    ESPNPC.byInstance = {}

    local function isPlayerCharacter(model)
        for _, plr in Players:GetPlayers() do
            if plr.Character == model then
                return true
            end
        end
        return false
    end

    local function ensureForNPC(model)
        if ESPNPC.byInstance[model] then return end
        if not model:IsA("Model") then return end
        if isPlayerCharacter(model) then return end
        local hum = model:FindFirstChildOfClass("Humanoid")
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end

        local hl = Instance.new("Highlight")
        hl.Name = "YBA_ESP_NPCHL"
        hl.Parent = model
        hl.FillTransparency = 1
        hl.OutlineTransparency = 0
        hl.OutlineColor = Color3.new(1, 0, 0)

        local bb = createNameBillboard(hrp, model.Name, Color3.new(1, 0, 0))
        ESPNPC.byInstance[model] = {hl = hl, bb = bb}
    end

    local function rescan()
        for _, desc in Workspace:GetDescendants() do
            if desc:IsA("Model") then
                ensureForNPC(desc)
            end
        end
    end

    rescan()

    local addedConn = Workspace.DescendantAdded:Connect(function(desc)
        if not ModuleManager.IsEnabled("ESPNPC") then return end
        task.wait(0.2)
        if desc:IsA("Model") then
            ensureForNPC(desc)
        end
    end)
    ModuleManager.AddConnection("ESPNPC", addedConn)

    local acc = 0
    local rescanConn = RunService.Heartbeat:Connect(function(dt)
        if not ModuleManager.IsEnabled("ESPNPC") then return end
        acc += dt
        if acc >= 0.6 then
            acc = 0
            rescan()
        end
    end)
    ModuleManager.AddConnection("ESPNPC", rescanConn)
end

function ESPNPC.OnDisable()
    for _, data in pairs(ESPNPC.byInstance) do
        if data.bb and data.bb.Parent then data.bb:Destroy() end
        if data.hl and data.hl.Parent then data.hl:Destroy() end
    end
    ESPNPC.byInstance = {}
end

