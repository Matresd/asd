-- Generic slider for any numeric value
function createSlider(parent, name, pos, min, max, default, valueCallback)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0, 220, 0, 45)
    frame.Position = pos
    frame.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = name .. ": " .. default
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextSize = 12
    
    local bar = Instance.new("Frame")
    bar.Parent = frame
    bar.Size = UDim2.new(1, -10, 0, 12)
    bar.Position = UDim2.new(0, 5, 0, 28)
    bar.BackgroundColor3 = Color3.new(0.4, 0.4, 0.4)
    
    local knob = Instance.new("TextButton")
    knob.Parent = bar
    knob.Size = UDim2.new(0, 16, 1, 0)
    knob.Position = UDim2.new((default - min) / (max - min), -8, 0, 0)
    knob.BackgroundColor3 = Color3.new(0.8, 0.8, 0.8)
    knob.Text = ""
    
    local dragging = false
    local currentVal = default
    
    local function updateValue(val)
        currentVal = math.clamp(val, min, max)
        label.Text = name .. ": " .. math.floor(currentVal)
        knob.Position = UDim2.new((currentVal - min) / (max - min), -8, 0, 0)
        if valueCallback then
            valueCallback(currentVal)
        end
    end
    
    knob.MouseButton1Down:Connect(function() dragging = true end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local relX = (input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X
            relX = math.clamp(relX, 0, 1)
            local val = min + (max - min) * relX
            updateValue(val)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            updateValue(currentVal)
        end
    end)
    
    -- Initial set
    updateValue(default)
    
    return frame
end

