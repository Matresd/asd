-- Module Manager
local ModuleManager = {}
local modules = {}

function ModuleManager.Register(module)
    if module.Name and type(module.OnEnable) == "function" and type(module.OnDisable) == "function" then
        modules[module.Name] = {
            Module = module,
            Enabled = false,
            Connections = {}
        }
        return true
    end
    return false
end

function ModuleManager.Toggle(moduleName, state)
    local moduleData = modules[moduleName]
    if not moduleData then return false end
    
    if state and not moduleData.Enabled then
        moduleData.Enabled = true
        local success, err = pcall(moduleData.Module.OnEnable)
        if not success then
            warn("Error enabling " .. moduleName .. ": " .. tostring(err))
            moduleData.Enabled = false
            return false
        end
    elseif not state and moduleData.Enabled then
        moduleData.Enabled = false
        for _, conn in ipairs(moduleData.Connections) do
            if conn and conn.Disconnect then conn:Disconnect() end
        end
        moduleData.Connections = {}
        pcall(moduleData.Module.OnDisable)
    end
    return true
end

function ModuleManager.IsEnabled(moduleName)
    local data = modules[moduleName]
    return data and data.Enabled or false
end

function ModuleManager.AddConnection(moduleName, connection)
    local data = modules[moduleName]
    if data and connection then
        table.insert(data.Connections, connection)
    end
end

