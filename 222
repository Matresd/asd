        local newState = not ModuleManager.IsEnabled(moduleName)
        ModuleManager.Toggle(moduleName, newState)
        btn.Text = name .. ": " .. (newState and "ON" or "OFF")
        btn.BackgroundColor3 = newState and Color3.new(0.2, 0.6, 0.2) or Color3.new(0.3, 0.3, 0.3)
