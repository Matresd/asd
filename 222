CombatModule = {
    Name = "Combat",
    Enabled = false,
    Connections = {},
    Target = nil,
    SelectedPlayer = nil,
    SelectedPlayerName = nil,
    AttachDistance = 2,  -- Inside target, slightly in front for hit registration
    PredictionStrength = 0,  -- No prediction, direct hits
    AttackRange = 10,
    AttackDelay = 0.06,
    LastAttackAt = 0,
    StandSummonKey = Enum.KeyCode.Q,
    SummonDelay = 1.0,
    LastSummonAt = 0,
    SkillKeys = {Enum.KeyCode.R},
    SkillDelay = 0.12,
    SkillHoldTime = 0.03,
    LastSkillAt = 0,
    NextSkillIndex = 1,
    LoopConnection = nil,
    DefaultCameraSubject = nil,
    LastStandModel = nil,
    LastStandAt = 0
}

function CombatModule.TrackConnection(connection)
    if connection then
        table.insert(CombatModule.Connections, connection)
    end
end

function CombatModule.DisconnectAll()
    for _, connection in ipairs(CombatModule.Connections) do
        if connection and connection.Disconnect then
            connection:Disconnect()
        end
    end
    CombatModule.Connections = {}
end

function CombatModule.ValidateTarget(model)
    if not model or not model:IsA("Model") then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return false end
    return hum.Health > 0
end

function CombatModule.GetPlayersList()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            table.insert(list, plr)
        end
    end
    table.sort(list, function(a, b)
        return a.Name:lower() < b.Name:lower()
    end)
    return list
end

function CombatModule.SelectNextPlayer()
    local list = CombatModule.GetPlayersList()
    if #list == 0 then
        CombatModule.SelectedPlayer = nil
        CombatModule.SelectedPlayerName = nil
        CombatModule.Target = nil
        return
    end

    local idx = 0
    for i, plr in ipairs(list) do
        if CombatModule.SelectedPlayer == plr then
            idx = i
            break
        end
    end
    local nextIndex = idx + 1
    if nextIndex > #list then
        nextIndex = 1
    end

    CombatModule.SelectedPlayer = list[nextIndex]
    CombatModule.SelectedPlayerName = CombatModule.SelectedPlayer.Name
    CombatModule.Target = CombatModule.SelectedPlayer.Character
end

function CombatModule.UpdateTarget()
    local selected = CombatModule.SelectedPlayer
    if not selected or selected == player then
        CombatModule.Target = nil
        CombatModule.SelectedPlayer = nil
        CombatModule.SelectedPlayerName = nil
        return
    end
    CombatModule.SelectedPlayerName = selected.Name
    local character = selected.Character
    if CombatModule.ValidateTarget(character) then
        CombatModule.Target = character
    else
        CombatModule.Target = nil
    end
end

function CombatModule.GetActiveTool()
    local char = player.Character
    if not char then return nil end
    for _, item in ipairs(char:GetChildren()) do
        if item:IsA("Tool") then
            return item
        end
    end
    return nil
end

function CombatModule.EnsureActiveTool()
    local equipped = CombatModule.GetActiveTool()
    if equipped then return equipped end
    local backpack = player:FindFirstChildOfClass("Backpack")
    local char = player.Character
    if not backpack or not char then return nil end
    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            item.Parent = char
            return item
        end
    end
    return nil
end

function CombatModule.GetModelRoot(model)
    if not model or not model:IsA("Model") then return nil end
    local root = model:FindFirstChild("HumanoidRootPart")
    if root and root:IsA("BasePart") then return root end
    if model.PrimaryPart and model.PrimaryPart:IsA("BasePart") then return model.PrimaryPart end
    return model:FindFirstChildWhichIsA("BasePart", true)
end

function CombatModule.GetLocalStandModel()
    local now = tick()
    if CombatModule.LastStandModel and CombatModule.LastStandModel.Parent and (now - CombatModule.LastStandAt) <= 0.35 then
        return CombatModule.LastStandModel
    end

    local char = player.Character
    if not char then return nil end

    local function cacheAndReturn(model)
        CombatModule.LastStandModel = model
        CombatModule.LastStandAt = now
        return model
    end

    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Model") and child.Name:lower():find("stand") then
            if CombatModule.GetModelRoot(child) then
                return cacheAndReturn(child)
            end
        end
    end

    for _, desc in ipairs(Workspace:GetDescendants()) do
        if desc:IsA("Model") and desc.Name:lower():find("stand") then
            local owner = desc:FindFirstChild("Owner")
            local user = desc:FindFirstChild("User")
            local userId = desc:FindFirstChild("UserId")
            local ownerMatch = false
            if owner and owner:IsA("ObjectValue") and owner.Value == player then ownerMatch = true end
            if user and user:IsA("ObjectValue") and user.Value == player then ownerMatch = true end
            if userId and userId:IsA("IntValue") and userId.Value == player.UserId then ownerMatch = true end
            if desc.Name:lower():find(player.Name:lower()) then ownerMatch = true end
            if ownerMatch and CombatModule.GetModelRoot(desc) then
                return cacheAndReturn(desc)
            end
        end
    end

    -- Fallback: nearest non-player humanoid model near local player.
    local localRoot = getRootPart()
    if localRoot then
        local nearest, minDist = nil, 30
        for _, desc in ipairs(Workspace:GetDescendants()) do
            if desc:IsA("Model") and desc ~= char then
                local isPlayerChar = false
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character == desc then
                        isPlayerChar = true
                        break
                    end
                end
                if not isPlayerChar then
                    local hum = desc:FindFirstChildOfClass("Humanoid")
                    local root = CombatModule.GetModelRoot(desc)
                    if hum and root and hum.Health > 0 then
                        local dist = (localRoot.Position - root.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            nearest = desc
                        end
                    end
                end
            end
        end
        if nearest then
            return cacheAndReturn(nearest)
        end
    end

    return nil
end

function CombatModule.GetLocalStandRoot()
    local standModel = CombatModule.GetLocalStandModel()
    if standModel then
        return CombatModule.GetModelRoot(standModel)
    end
    return nil
end

function CombatModule.GetStandCameraSubject()
    local stand = CombatModule.GetLocalStandModel()
    if not stand then return nil end
    local standHum = stand:FindFirstChildOfClass("Humanoid")
    if standHum then return standHum end
    return CombatModule.GetModelRoot(stand)
end

function CombatModule.GetAttackOriginPart()
    return CombatModule.GetLocalStandRoot() or getRootPart()
end

function CombatModule.TrySummonStand()
    local now = tick()
    if now - CombatModule.LastSummonAt < CombatModule.SummonDelay then return end
    CombatModule.LastSummonAt = now
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, CombatModule.StandSummonKey, false, game)
        VirtualInputManager:SendKeyEvent(false, CombatModule.StandSummonKey, false, game)
    end)
end

function CombatModule.EnsureStandReady()
    local standRoot = CombatModule.GetLocalStandRoot()
    if standRoot then return standRoot end
    CombatModule.TrySummonStand()
    return nil
end

function CombatModule.PerformAttack(target, ignoreRange)
    if not ignoreRange then
        if not CombatModule.ValidateTarget(target) then return end
        local root = CombatModule.GetLocalStandRoot() or CombatModule.GetAttackOriginPart()
        local targetRoot = target:FindFirstChild("HumanoidRootPart")
        if not root or not targetRoot then return end
        if (root.Position - targetRoot.Position).Magnitude > CombatModule.AttackRange then return end
    end

    local now = tick()
    if now - CombatModule.LastAttackAt < CombatModule.AttackDelay then return end

    local tool = CombatModule.EnsureActiveTool()
    CombatModule.LastAttackAt = now

    if tool then
        pcall(function()
            tool:Activate()
        end)
    end
    
    -- Always emulate LMB for stand attacks
    -- Use VirtualUser as primary method (works better for YBA)
    pcall(function()
        local mouse = player:GetMouse()
        local pos = Vector2.new(mouse.X, mouse.Y)
        VirtualUser:CaptureController()
        VirtualUser:Button1Down(pos)
        task.wait(0.01)
        VirtualUser:Button1Up(pos)
    end)
    
    -- Fallback to VirtualInputManager
    pcall(function()
        local mouse = player:GetMouse()
        local mx, my = mouse.X, mouse.Y
        VirtualInputManager:SendMouseButtonEvent(mx, my, 0, true, game, 1)
        task.wait(0.005)
        VirtualInputManager:SendMouseButtonEvent(mx, my, 0, false, game, 1)
    end)
end

function CombatModule.UseNextSkill()
    local now = tick()
    if now - CombatModule.LastSkillAt < CombatModule.SkillDelay then return end

    local key = Enum.KeyCode.R

    CombatModule.LastSkillAt = now
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.delay(CombatModule.SkillHoldTime, function()
            pcall(function()
                VirtualInputManager:SendKeyEvent(false, key, false, game)
            end)
        end)
    end)

    CombatModule.NextSkillIndex = 1
end

function CombatModule.FaceTarget(target)
    local root = CombatModule.GetAttackOriginPart()
    local targetRoot = target and target:FindFirstChild("HumanoidRootPart")
    if not root or not targetRoot then return end
    local lookPos = Vector3.new(targetRoot.Position.X, root.Position.Y, targetRoot.Position.Z)
    root.CFrame = CFrame.lookAt(root.Position, lookPos)
end

function CombatModule.GetPredictedPosition(targetRoot)
    if not targetRoot then return nil end
    local velocity = targetRoot.AssemblyLinearVelocity or Vector3.new()
    return targetRoot.Position + velocity * CombatModule.PredictionStrength
end

function CombatModule.AttachToTarget(target)
    local root = CombatModule.GetLocalStandRoot()
    local targetRoot = target and target:FindFirstChild("HumanoidRootPart")
    if not root or not targetRoot then return end

    -- Position stand INSIDE target, slightly in front for hit registration
    -- This ensures the stand's hitbox overlaps with target's hitbox
    local targetPos = targetRoot.Position
    local targetLook = targetRoot.CFrame.LookVector
    
    -- Place stand 2 studs inside target, in the direction target is facing
    -- This puts the stand's attack hitbox INSIDE the target's hitbox
    local insideOffset = targetLook * 2  -- Inside toward facing direction
    local finalPos = targetPos + insideOffset + Vector3.new(0, 0.5, 0)  -- Slightly up from center
    
    -- Look at target's center to ensure attacks hit
    root.CFrame = CFrame.lookAt(finalPos, targetPos)
end

function CombatModule.StartLoop()
    CombatModule.StopLoop()
    CombatModule.LoopConnection = RunService.Heartbeat:Connect(function()
        if not CombatModule.Enabled then return end

        if ModuleManager.IsEnabled("ViewStand") then
            local standSubject = CombatModule.GetStandCameraSubject()
            if standSubject then
                camera.CameraSubject = standSubject
            end
        end

        CombatModule.UpdateTarget()
        local target = CombatModule.Target
        local hasSelectedPlayer = CombatModule.SelectedPlayer ~= nil

        -- Always spam attacks when StandAttach enabled and player selected, even if target far/not loaded
        if ModuleManager.IsEnabled("StandAttach") and hasSelectedPlayer then
            CombatModule.PerformAttack(target, true)
            CombatModule.UseNextSkill()
        end

        -- Only proceed with movement logic if target is valid
        if not CombatModule.ValidateTarget(target) then
            if not ModuleManager.IsEnabled("ViewStand") and CombatModule.DefaultCameraSubject then
                camera.CameraSubject = CombatModule.DefaultCameraSubject
            end
            return
        end

        local standRoot = CombatModule.EnsureStandReady()
        if ModuleManager.IsEnabled("StandAttach") then
            if standRoot then
                CombatModule.AttachToTarget(target)
            end
        end

        if ModuleManager.IsEnabled("FollowStand") then
            if standRoot then
                CombatModule.FaceTarget(target)
            end
        end

        if not ModuleManager.IsEnabled("ViewStand") and CombatModule.DefaultCameraSubject then
            camera.CameraSubject = CombatModule.DefaultCameraSubject
        end
    end)
    CombatModule.TrackConnection(CombatModule.LoopConnection)
end

function CombatModule.StopLoop()
    if CombatModule.LoopConnection then
        CombatModule.LoopConnection:Disconnect()
        CombatModule.LoopConnection = nil
    end
end

function CombatModule.CycleAttachDistance()
    local values = {5, 8, 10, 12, 15}
    local idx = 1
    for i, v in ipairs(values) do
        if v == CombatModule.AttachDistance then
            idx = i
            break
        end
    end
    idx += 1
    if idx > #values then idx = 1 end
    CombatModule.AttachDistance = values[idx]
end

function CombatModule.CyclePredictionStrength()
    local values = {0.00, 0.08, 0.12, 0.15, 0.20, 0.28}
    local idx = 1
    for i, v in ipairs(values) do
        if math.abs(v - CombatModule.PredictionStrength) < 0.001 then
            idx = i
            break
        end
    end
    idx += 1
    if idx > #values then idx = 1 end
    CombatModule.PredictionStrength = values[idx]
end

function CombatModule.OnEnable()
    CombatModule.Enabled = true
    CombatModule.DefaultCameraSubject = camera.CameraSubject
    CombatModule.LastAttackAt = 0
    CombatModule.LastSkillAt = 0
    CombatModule.NextSkillIndex = 1
    CombatModule.LastSummonAt = 0
    CombatModule.LastStandModel = nil
    CombatModule.LastStandAt = 0
    CombatModule.UpdateTarget()

    local charAdded = player.CharacterAdded:Connect(function()
        task.wait(0.1)
        local hum = getHumanoid()
        if hum and not ModuleManager.IsEnabled("ViewStand") then
            camera.CameraSubject = hum
        end
    end)
    CombatModule.TrackConnection(charAdded)
    ModuleManager.AddConnection("Combat", charAdded)

    local playerRemoving = Players.PlayerRemoving:Connect(function(plr)
        if CombatModule.SelectedPlayer == plr then
            CombatModule.SelectedPlayer = nil
            CombatModule.SelectedPlayerName = nil
            CombatModule.Target = nil
        end
    end)
    CombatModule.TrackConnection(playerRemoving)
    ModuleManager.AddConnection("Combat", playerRemoving)

    CombatModule.StartLoop()
    if CombatModule.LoopConnection then
        ModuleManager.AddConnection("Combat", CombatModule.LoopConnection)
    end
end

